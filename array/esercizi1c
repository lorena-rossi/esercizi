#include <stdio.h>
#include <string.h>

void stampa(int a[] , int n ){
    for (int i = 0; i < n; i++)
    {
        printf("%d", a[i]);
    }
    
};

int trova_max( const double *a, int n, double *max_out){
    if ( a == NULL || n <= 0 || max_out==NULL)
    {
        return -1;
    }
    *max_out = a[0];
    for (int i = 0; i < n; i++)
    {
        if (*max_out < a[i])
        {
            *max_out = a[i];
        }  
    }
    return 0; 
    
};

int main(){

    int v[]={1, 2, 3, 4, 5};
    int n = 5;
    stampa(v,n);
    return 0;
}
